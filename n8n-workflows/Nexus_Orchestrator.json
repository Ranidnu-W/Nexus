        "method": "POST",
        "url": "={{ $env.OLLAMA_URL }}/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama3', stream: false, messages: [ { role: 'system', content: 'You are an intent classifier. Given a user message, determine which agent should handle it.\\nRespond ONLY with valid JSON: { \"agent\": \"<agent_name>\", \"confidence\": <0.0-1.0> }\\n\\nAgents:\\n- docmentor: Questions about uploaded documents, \"what does the doc say about...\"\\n- review: Analyzing reviews, sentiment, extracting patterns from review text\\n- digest: Setting up content digests, topic subscriptions, \"send me updates about...\"\\n- file: Uploading files, processing documents, \"parse this PDF\"\\n- general: Anything that doesn\\'t fit the above\\n\\nDo not explain. JSON only.' }, { role: 'user', content: $json.message } ] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "be17dcb7-fe24-4490-b6f0-34247a884c68",
      "name": "Classify Intent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -656,
        240
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const response = $json;\nconst content = response.message?.content || response.response || '';\nconst sessionId = $('Extract Input').first().json.session_id;\nconst originalMessage = $('Extract Input').first().json.message;\n\nlet agent = 'general';\nlet confidence = 0;\n\ntry {\n  let jsonStr = content;\n  const codeBlockMatch = content.match(/```(?:json)?\\s*([\\s\\S]*?)```/);\n  if (codeBlockMatch) {\n    jsonStr = codeBlockMatch[1];\n  } else {\n    const jsonMatch = content.match(/\\{[\\s\\S]*\\}/);\n    if (jsonMatch) jsonStr = jsonMatch[0];\n  }\n  \n  const parsed = JSON.parse(jsonStr);\n  agent = parsed.agent || 'general';\n  confidence = parseFloat(parsed.confidence) || 0;\n} catch (e) {\n  agent = 'general';\n  confidence = 0;\n}\n\nconst validAgents = ['docmentor', 'review', 'digest', 'file', 'general'];\nif (!validAgents.includes(agent)) agent = 'general';\n\nreturn [{\n  json: {\n    agent: agent,\n    confidence: confidence,\n    session_id: sessionId,\n    original_message: originalMessage,\n    start_time: $('Extract Input').first().json.start_time\n  }\n}];"
      },
