        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama3', stream: false, messages: [ { role: 'system', content: 'You are Nexus, a helpful AI assistant. You are part of a multi-agent platform that includes specialized agents for document Q&A (DocMentor), review analysis, content digests, and file processing. Answer the user\\'s question helpfully and concisely. If their request would be better handled by a specific agent, mention it.' }, { role: 'user', content: $('Parse Intent').first().json.original_message } ] }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "4c0e1fee-b238-476c-8602-c5c42f372646",
      "name": "General Chat",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        560
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const agent = $('Parse Intent').first().json.agent;\nconst sessionId = $('Parse Intent').first().json.session_id;\nconst data = $json;\n\nlet response = '';\n\nif (agent === 'docmentor') {\n  // DocMentor returns async job_id\n  if (data.job_id) {\n    response = JSON.stringify({ job_id: data.job_id, status: data.status || 'processing' });\n  } else {\n    response = data.response || 'DocMentor is processing your request.';\n  }\n} else if (agent === 'review') {\n  response = data.summary || JSON.stringify(data);\n} else if (agent === 'digest') {\n  if (data.content) {\n    response = 'Here is your latest digest. Check the Digest page for the full content.';\n  } else {\n    response = 'No digests found. Configure one on the Digest page.';\n  }\n} else if (agent === 'file') {\n  response = data.agent_response || 'Please use the File Manager page to upload files.';\n} else {\n  // General chat\n  response = data.message?.content || data.response || 'I\\'m not sure how to help with that. Try asking about your documents, reviews, or digests.';\n}\n\nreturn [{\n  json: {\n    agent: agent,\n    response: response,\n    session_id: sessionId\n  }\n}];"
      },
