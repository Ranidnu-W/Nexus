    {
      "parameters": {
        "jsCode": "const check = async (url, timeout) => {\n  const start = Date.now();\n  try {\n    await this.helpers.httpRequest({ method: 'GET', url, timeout });\n    return { status: 'up', response_ms: Date.now() - start };\n  } catch(e) {\n    return { status: 'down', response_ms: Date.now() - start };\n  }\n};\n\nconst [ollama, qdrant, docling, n8n] = await Promise.all([\n  check($env.OLLAMA_URL + '/api/tags', 10000),\n  check($env.QDRANT_URL + '/healthz', 10000),\n  check($env.DOCLING_URL + '/health', 10000),\n  check($env.N8N_URL + '/healthz', 10000)\n]);\n\nreturn [{\n  json: {\n    timestamp: new Date().toISOString(),\n    ollama,\n    qdrant,\n    docling,\n    n8n,\n    all_healthy: ollama.status === 'up' && qdrant.status === 'up' && docling.status === 'up' && n8n.status === 'up'\n  }\n}];"
      },
