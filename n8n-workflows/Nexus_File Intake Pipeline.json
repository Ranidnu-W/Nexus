    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst chunkData = $('Chunk Text').all();\nconst points = [];\n\nfor (let i = 0; i < allItems.length; i++) {\n  const embedding = allItems[i].json.embedding;\n  if (!embedding || !Array.isArray(embedding)) continue;\n  \n  const chunk = chunkData[i]?.json || {};\n  const chunkId = chunk.chunk_id || Array.from({length: 32}, () => Math.random().toString(36)[2]).join('');\n  \n  points.push({\n    id: i + 1,\n    vector: embedding,\n    payload: {\n      text: chunk.text || '',\n      document_id: chunk.document_id || '',\n      file_name: chunk.file_name || '',\n      chunk_index: chunk.chunk_index || 0,\n      created_at: new Date().toISOString()\n    }\n  });\n}\n\nconst documentId = $('Generate Job ID').first().json.document_id;\n\nreturn [{\n  json: {\n    document_id: documentId,\n    points: points,\n    chunk_count: points.length\n  }\n}];"
      },
