      "parameters": {
        "jsCode": "const jobId = Array.from({length: 32}, () => Math.random().toString(36)[2]).join('');\nconst binary = $input.first().binary;\nconst fileKey = binary ? Object.keys(binary)[0] : null;\nconst fileMeta = fileKey ? binary[fileKey] : {};\nconst fileName = fileMeta.fileName || 'unknown';\nconst fileSize = parseInt(fileMeta.fileSize) || 0;\nconst ext = fileName.split('.').pop()?.toLowerCase() || '';\n\n// Read text content now while binary is still available\nlet rawText = '';\nif (fileKey && ['txt', 'md', 'csv', 'json'].includes(ext)) {\n  try {\n    const buffer = await this.helpers.getBinaryDataBuffer(0, fileKey);\n    rawText = buffer.toString('utf-8');\n  } catch(e) {}\n}\n\nreturn [{\n  json: {\n    job_id: jobId,\n    document_id: jobId,\n    file_name: fileName,\n    file_size: fileSize,\n    file_extension: ext,\n    start_time: Date.now(),\n    raw_text: rawText\n  },\n  binary: $input.first().binary\n}];"
      },
