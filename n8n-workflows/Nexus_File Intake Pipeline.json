    {
      "parameters": {
        "jsCode": "const data = $('Generate Job ID').first().json;\nreturn [{\n  json: {\n    ...data,\n    extracted_text: data.raw_text || '',\n    parse_method: 'direct_read'\n  }\n}];"
      },
      "id": "eda8b246-6140-46e0-a6ce-8ef6886cd0f9",
      "name": "Read Text Content",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const binary = $input.first().binary;\nconst fileKey = binary ? Object.keys(binary)[0] : null;\nlet text = '';\n\nif (fileKey && binary[fileKey]) {\n  const buffer = await this.helpers.getBinaryDataBuffer(0, fileKey);\n  const raw = buffer.toString('utf-8');\n  const ext = $('Generate Job ID').first().json.file_extension;\n  \n  if (ext === 'csv') {\n    // Convert CSV to readable text representation\n    const lines = raw.split('\\n').filter(l => l.trim());\n    text = lines.map(line => line.replace(/,/g, ' | ')).join('\\n');\n  } else if (ext === 'json') {\n    // Pretty-print JSON\n    try {\n      const parsed = JSON.parse(raw);\n      text = JSON.stringify(parsed, null, 2);\n    } catch (e) {\n      text = raw;\n    }\n  } else {\n    text = raw;\n  }\n}\n\nconst data = $('Generate Job ID').first().json;\nreturn [{\n  json: {\n    ...data,\n    extracted_text: text,\n    parse_method: 'structured_parse'\n  }\n}];"
      },
      "id": "71d49e6c-fd62-449a-a4e8-6ebeb8bfea72",
      "name": "Parse CSV/JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        368
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $('Generate Job ID').first().json;\nreturn [{\n  json: {\n    ...data,\n    error: true,\n    error_message: `Unsupported file type: .${data.file_extension}`\n  }\n}];"
      },
      "id": "13333e4f-cf95-450a-b1ba-c1ee5df7c7b8",
      "name": "Unsupported Type Error",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        544
      ]
    },
    {
      "parameters": {
        "jsCode": "// Handle Docling response for PDF path\nconst doclingResponse = $json;\nconst data = $('Generate Job ID').first().json;\nconst text = doclingResponse.markdown || doclingResponse.text || doclingResponse.content || '';\n\nif (!text && doclingResponse.error) {\n  return [{\n    json: {\n      ...data,\n      error: true,\n      error_message: 'Docling failed to parse PDF: ' + (doclingResponse.error || 'unknown error')\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...data,\n    extracted_text: text,\n    parse_method: 'docling'\n  }\n}];"
      },
