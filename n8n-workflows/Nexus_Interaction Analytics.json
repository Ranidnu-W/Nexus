    {
      "parameters": {
        "jsCode": "const interactions = $input.all().map(item => item.json.fields || item.json);\nconst total = interactions.length;\n\n// By agent\nconst byAgent = {};\ninteractions.forEach(i => {\n  const agent = i.agent || 'unknown';\n  byAgent[agent] = (byAgent[agent] || 0) + 1;\n});\n\n// Avg response time (only successful ones with valid times)\nconst responseTimes = interactions\n  .map(i => parseInt(i.response_time_ms) || 0)\n  .filter(t => t > 0);\nconst avgResponseMs = responseTimes.length > 0\n  ? Math.round(responseTimes.reduce((a, b) => a + b, 0) / responseTimes.length)\n  : 0;\n\n// Error rate\nconst errors = interactions.filter(i => i.status === 'error').length;\nconst errorRate = total > 0 ? parseFloat((errors / total).toFixed(4)) : 0;\n\n// Peak hour\nconst hourCounts = {};\ninteractions.forEach(i => {\n  if (i.created_at) {\n    try {\n      const hour = new Date(i.created_at).getHours();\n      hourCounts[hour] = (hourCounts[hour] || 0) + 1;\n    } catch (e) { /* skip invalid dates */ }\n  }\n});\nconst peakHour = Object.keys(hourCounts).length > 0\n  ? parseInt(Object.entries(hourCounts).sort((a, b) => b[1] - a[1])[0][0])\n  : 0;\n\n// Top document (from docmentor interactions input_preview)\nconst docMentions = {};\ninteractions.forEach(i => {\n  if (i.agent === 'docmentor' && i.input_preview) {\n    const key = i.input_preview.slice(0, 80);\n    docMentions[key] = (docMentions[key] || 0) + 1;\n  }\n});\nconst topDocument = Object.keys(docMentions).length > 0\n  ? Object.entries(docMentions).sort((a, b) => b[1] - a[1])[0][0]\n  : '';\n\nreturn [{\n  json: {\n    period: 'hourly',\n    total_interactions: total,\n    by_agent: JSON.stringify(byAgent),\n    avg_response_ms: avgResponseMs,\n    error_rate: errorRate,\n    peak_hour: peakHour,\n    top_document: topDocument\n  }\n}];"
      },
