    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) {\n  return [{\n    json: {\n      total_interactions: 0,\n      by_agent: {},\n      avg_response_ms: 0,\n      error_rate: 0,\n      peak_hour: 0,\n      top_document: ''\n    }\n  }];\n}\n\nconst record = items[0].json.fields || items[0].json;\n\nlet byAgent = {};\ntry {\n  byAgent = typeof record.by_agent === 'string' ? JSON.parse(record.by_agent) : (record.by_agent || {});\n} catch (e) {\n  byAgent = {};\n}\n\nreturn [{\n  json: {\n    total_interactions: record.total_interactions || 0,\n    by_agent: byAgent,\n    avg_response_ms: record.avg_response_ms || 0,\n    error_rate: record.error_rate || 0,\n    peak_hour: record.peak_hour || 0,\n    top_document: record.top_document || ''\n  }\n}];"
      },
