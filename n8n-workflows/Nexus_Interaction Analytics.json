      "id": "0361f10d-454e-42f9-9210-d7b0d79ff7d7",
      "name": "Read Recent Interactions",
      "type": "n8n-nodes-base.airtable",
      "typeVersion": 2.1,
      "position": [
        240,
        0
      ],
      "credentials": {
