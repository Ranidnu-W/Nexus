    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst thirtyDaysAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000).toISOString();\nconst sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000).toISOString();\n\nreturn [{\n  json: {\n    thirty_days_ago: thirtyDaysAgo,\n    seven_days_ago: sevenDaysAgo,\n    run_timestamp: now.toISOString()\n  }\n}];"
      },
      "id": "faf668e1-b5c6-4e3d-8cf2-5c808cc2088e",
      "name": "Calculate Cutoff Dates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        208
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.QDRANT_URL }}/collections/docmentor/points/delete",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ filter: { must: [{ key: 'created_at', range: { lt: $json.thirty_days_ago } }] } }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "35f170af-653a-43e1-9410-bb34cbab1112",
