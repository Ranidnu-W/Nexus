    {
      "parameters": {
        "jsCode": "// Aggregate all cleanup results\nlet vectorsDeleted = 0;\ntry {\n  const qdrantResult = $('Delete Old Vectors').first().json;\n  vectorsDeleted = qdrantResult.result?.deleted || qdrantResult.deleted || 0;\n} catch(e) { /* Qdrant may not have returned a count */ }\n\nlet interactionsArchived = 0;\ntry {\n  interactionsArchived = $('Archive Old Interactions').first().json.interactions_archived || 0;\n} catch(e) {}\n\nlet healthLogsDeleted = 0;\ntry {\n  healthLogsDeleted = $('Count Old Health Logs').first().json.health_logs_found || 0;\n} catch(e) {}\n\nlet errorDocsCleaned = 0;\ntry {\n  errorDocsCleaned = $('Count Error Documents').first().json.error_docs_found || 0;\n} catch(e) {}\n\nreturn [{\n  json: {\n    run_at: new Date().toISOString(),\n    vectors_pruned: vectorsDeleted,\n    records_archived: interactionsArchived,\n    logs_deleted: healthLogsDeleted,\n    error_docs_cleaned: errorDocsCleaned,\n    total_cleaned: vectorsDeleted + interactionsArchived + healthLogsDeleted + errorDocsCleaned\n  }\n}];"
      },
