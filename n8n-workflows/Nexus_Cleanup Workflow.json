    {
      "parameters": {
        "jsCode": "// Count the interactions found and mark for archival\nconst items = $input.all();\nconst count = items.length;\n\n// For each record, we'd update status to 'archived'\n// In a real implementation you'd loop and update each\n// For now, we just count\nreturn [{\n  json: {\n    interactions_archived: count\n  }\n}];"
      },
