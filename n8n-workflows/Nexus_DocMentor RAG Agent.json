    {
      "parameters": {
        "jsCode": "const response = $json;\nconst content = response.message?.content || response.response || 'I was unable to generate a response. Please try again.';\nconst jobId = $('Generate Query Job ID').first().json.job_id;\nconst sources = $('Assemble Context').first().json.sources;\nconst chunkCount = $('Assemble Context').first().json.chunk_count;\n\nreturn [{\n  json: {\n    job_id: jobId,\n    response: content,\n    sources: sources,\n    chunk_count: chunkCount\n  }\n}];"
      },
