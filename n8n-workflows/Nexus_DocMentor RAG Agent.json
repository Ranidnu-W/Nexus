    {
      "parameters": {
        "jsCode": "const searchResponse = $json;\nconst results = searchResponse.result || searchResponse || [];\nconst query = $('Generate Query Job ID').first().json.query;\n\nconst chunks = (Array.isArray(results) ? results : []).map((r, i) => {\n  const payload = r.payload || {};\n  return `[Source ${i + 1}: ${payload.file_name || 'Unknown Document'}]\\n${payload.text || ''}`;\n});\n\nconst context = chunks.length > 0\n  ? chunks.join('\\n\\n---\\n\\n')\n  : 'No relevant documents found. Please answer based on your general knowledge and mention that no matching documents were found.';\n\nconst sources = (Array.isArray(results) ? results : [])\n  .map(r => r.payload?.file_name)\n  .filter(Boolean)\n  .filter((v, i, a) => a.indexOf(v) === i);\n\nreturn [{\n  json: {\n    context: context,\n    query: query,\n    chunk_count: chunks.length,\n    sources: sources\n  }\n}];"
      },
      "id": "29891fdf-6d1a-4c17-a1be-6bbaf45c0619",
      "name": "Assemble Context",
