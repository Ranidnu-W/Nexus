        "url": "={{ $env.OLLAMA_URL }}/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama3', stream: false, messages: [ { role: 'system', content: 'You are DocMentor, an AI assistant that answers questions based on uploaded documents. Answer based on the provided context. Always cite which document your answer comes from. If the context does not contain relevant information, say so clearly.' }, { role: 'user', content: 'Context:\\n' + $json.context + '\\n\\nQuestion: ' + $json.query } ] }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "061020e8-1ee3-4f76-b06b-dc7f0480558c",
