        "jsCode": "const body = $json.body || $json;\nconst jobId = Array.from({length: 32}, () => Math.random().toString(36)[2]).join('');\n\nreturn [{\n  json: {\n    job_id: jobId,\n    query: body.query || body.message || '',\n    session_id: body.session_id || '',\n    document_filter: body.document_filter || null,\n    start_time: Date.now()\n  }\n}];"
